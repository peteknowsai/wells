# Bun / Node
node_modules/
bun.lockb
.bun/

# Build output
dist/
build/

# OS junk
.DS_Store
*.swp
.vscode/
.idea/

# Claude Code session runtime
.claude/scheduled_tasks.lock

# Local sprite/splite project file (per-cwd active splite)
.splite

# Vendored lume — we vendor source, not artifacts
vendor/lume/.build/
bin/lume
bin/lume.app/

# Apple signing material — never commit certs/profiles
vendor/lume.patches/*.provisionprofile
vendor/lume.patches/*.cer
vendor/lume.patches/*.p12

# Downloaded base images / disks (large, regenerable)
images/
*.img
*.qcow2
*.iso
*.vmdk

# Logs
*.log

# Env overrides
.env
.env.*
!.env.example
